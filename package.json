{
  "name": "naschi.at",
  "version": "0.3.0",
  "private": false,
  "description": "My personal Website",
  "author": "Daniel Naschberger <daniel@naschi.at>",
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "lint": "eslint 'src/**/*.{astro,js,ts,vue}' --fix --ignore-pattern 'src/env.d.ts'",
    "lint-no-fix": "eslint 'src/**/*.{astro,js,ts,vue}' --ignore-pattern 'src/env.d.ts'",
    "build": "astro build",
    "preview": "astro preview",
    "optimize-images": "mkdir -p src/media && rm -rf public/media/* && ./image-optimizer --source ./media/ --destination public/media --prefix /media/ --widths 384 512 640 768 1280 1536 --qualities 99 99 99 99 99 99 --jsonfile media.json && cp public/media/media.json src/media/media.json"
  },
  "dependencies": {
    "astro": "6.3.1",
    "heroicons": "2.2.0",
    "leaflet": "1.9.4",
    "vue": "3.5.34"
  },
  "devDependencies": {
    "@astrojs/vue": "6.0.1",
    "@types/leaflet": "1.9.21",
    "@types/node": "25.6.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/cli-plugin-eslint": "5.0.9",
    "@vue/cli-plugin-typescript": "5.0.9",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "eslint": "10.3.0",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-vue": "10.9.1",
    "prettier": "3.8.3",
    "prettier-eslint": "16.4.2",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
