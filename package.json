{
  "name": "naschi.at",
  "version": "1.0.0",
  "description": "My personal SPA website.",
  "author": "Daniel Naschberger",
  "private": true,
  "precommit": "npm run lint",
  "scripts": {
    "current-git-sha": "NUXT_ENV_CURRENT_GIT_SHA=`git rev-parse --short HEAD`",
    "dev": "npm run current-git-sha nuxt",
    "build": "nuxt build",
    "build:gh-pages": "NUXT_ENV_CURRENT_GIT_SHA=`git rev-parse --short HEAD` DEPLOY_ENV=GH_PAGES nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "generate:gh-pages": "NUXT_ENV_CURRENT_GIT_SHA=`git rev-parse --short HEAD` DEPLOY_ENV=GH_PAGES nuxt generate",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore .",
    "lintfix": "eslint --fix --ext .js,.vue --ignore-path .gitignore ."
  },
  "dependencies": {
    "nuxt": "^2.0.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^1.0.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-vue": "^6.2.2",
    "prettier": "^2.0.5"
  }
}
